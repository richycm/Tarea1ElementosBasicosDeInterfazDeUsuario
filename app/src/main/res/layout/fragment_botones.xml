<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Botones"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Los botones permiten al usuario realizar acciones con un toque. Pueden contener texto, imágenes o ser flotantes."
        android:layout_marginBottom="20dp"
        android:gravity="center"/>

    <!-- 1. Botón Normal -->
    <Button
        android:id="@+id/btnFilled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Botón Normal"
        android:layout_marginBottom="15dp"/>

    <!-- 2. ImageButton (con icono de cámara) -->
    <ImageButton
        android:id="@+id/btnImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_camera"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="10dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="Botón de cámara"/>

    <!-- 3. FloatingActionButton (el círculo flotante) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        app:elevation="4dp"
        android:contentDescription="Añadir"/>

</LinearLayout>