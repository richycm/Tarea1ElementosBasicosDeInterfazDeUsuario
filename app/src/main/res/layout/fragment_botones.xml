<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Botones (Interacción)"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los botones permiten al usuario realizar acciones con un solo toque. Prueba los diferentes estilos abajo."
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnFilled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Botón Normal"
                android:layout_marginBottom="16dp"/>

            <ImageButton
                android:id="@+id/btnImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_camera"
                android:layout_gravity="center"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="24dp"
                android:contentDescription="Cámara"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_input_add"
                android:layout_gravity="center"
                android:contentDescription="Añadir"/>

        </LinearLayout>
    </ScrollView>

    <!-- Panel de Info Aesthetic Abajo -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvInfoBotonesTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guía de Botones"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvInfoBotonesDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Toca un botón arriba para ver su descripción técnica aquí."
                android:textSize="14sp"
                android:textColor="#666666"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>