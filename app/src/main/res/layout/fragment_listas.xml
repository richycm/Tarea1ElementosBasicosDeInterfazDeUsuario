<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catálogo de Componentes"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:padding="20dp"/>

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="?attr/colorOutlineVariant"
        android:dividerHeight="0.5dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

    <!-- Panel de Información - Copiado de fragment_botones -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvInfoTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona un elemento"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvInfoDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Toca cualquier opción de la lista de arriba para ver su explicación técnica detallada aquí mismo."
                android:textSize="14sp"
                android:textColor="#666666"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>