<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elementos de Información"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estos elementos sirven para mostrar datos al usuario. El TextView muestra texto fijo, el ImageView muestra imágenes y el ProgressBar indica el estado de una carga."
        android:layout_marginBottom="30dp"
        android:gravity="center"/>

    <!-- Imagen de ejemplo (Estrella de Android) -->
    <ImageView
        android:id="@+id/imageViewInfo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/btn_star_big_on"
        android:layout_marginBottom="30dp"
        android:contentDescription="Estrella de ejemplo"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Progreso de una tarea (ProgressBar Horizontal):"
        android:layout_marginBottom="8dp"
        android:textStyle="italic"/>

    <!-- Barra de progreso con porcentaje (Horizontal) -->
    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progress="75"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buscando actualizaciones (ProgressBar Circular):"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        android:textStyle="italic"/>

    <!-- Barra de progreso de carga (Circular) -->
    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

</LinearLayout>