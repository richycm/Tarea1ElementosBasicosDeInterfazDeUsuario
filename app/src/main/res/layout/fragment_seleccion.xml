<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elementos de Selección"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="16dp"/>

            <!-- CheckBox Section -->
            <CheckBox
                android:id="@+id/cbTerminos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aceptar términos y condiciones"
                android:textSize="16sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- RadioButton Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elige tu plataforma preferida:"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <RadioGroup
                android:id="@+id/rgOpciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rbAndroid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Android (Kotlin)"/>
                <RadioButton
                    android:id="@+id/rbIos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="iOS (Swift)"/>
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

            <!-- Switch Section -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swModoOscuro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modo Oscuro"
                android:textSize="16sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

            <!-- Resultados simples (Resumen) -->
            <TextView
                android:id="@+id/tvResumenTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumen de Selección"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvResumenDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aquí aparecerán tus elecciones en tiempo real."
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"/>

        </LinearLayout>
    </ScrollView>

    <!-- Panel de Contexto/Guía - Estilo igual a Botones y Listas -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E0E0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvInfoSeleccionTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guía de Selección"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvInfoSeleccionDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Interactúa con los elementos arriba para conocer su función técnica."
                android:textSize="14sp"
                android:textColor="#666666"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>